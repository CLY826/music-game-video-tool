/* pages/profile/profile.wxss */

.profile-wrap {
  background: var(--bg);
  min-height: 100vh;
}

/* 用户信息卡 */
.user-card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 48rpx 28rpx 36rpx;
}

.user-info-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 28rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255,255,255,0.3);
  flex-shrink: 0;
}

.user-avatar {
  width: 100%;
  height: 100%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  background: rgba(108,99,255,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.5);
}

.user-stats {
  display: flex;
  gap: 48rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255,255,255,0.15);
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 600;
  color: #ffffff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
}

/* Tab 切换栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid var(--border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0 24rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.tab-item.tab-active {
  color: var(--primary);
  font-weight: 600;
}

.tab-item.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

/* 内容区 */
.content-section {
  padding: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding-left: 16rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6rpx;
  height: 32rpx;
  width: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

.upload-mini-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 10rpx 24rpx;
  font-size: 26rpx;
}

/* 单个视频项（发布 & 收藏共用） */
.my-video-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.my-video-left {
  flex-shrink: 0;
}

.my-thumb {
  width: 160rpx;
  height: 96rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #1a1a2e;
}

.my-thumb-img {
  width: 100%;
  height: 100%;
}

.my-thumb-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: rgba(255,255,255,0.3);
}

.my-video-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.my-video-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.my-video-game {
  font-size: 24rpx;
  color: var(--primary);
}

.my-video-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.my-video-comment {
  font-size: 22rpx;
  color: var(--text-hint);
}

.my-video-uploader {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 删除按钮 */
.delete-btn {
  font-size: 36rpx;
  padding: 12rpx;
  flex-shrink: 0;
  color: var(--text-hint);
}

/* 取消收藏按钮 */
.unfav-btn {
  font-size: 36rpx;
  padding: 12rpx;
  flex-shrink: 0;
  color: #ff6b9d;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
  gap: 16rpx;
}

.icon {
  font-size: 80rpx;
}

.tip {
  font-size: 28rpx;
  color: var(--text-hint);
}

.tip-sub {
  font-size: 24rpx;
  color: var(--text-hint);
}

.go-upload-btn {
  margin-top: 16rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
