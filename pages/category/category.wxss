/* pages/category/category.wxss */

.category-wrap {
  padding: 0 0 40rpx;
  background: var(--bg);
  min-height: 100vh;
}

.sort-bar {
  display: flex;
  background: #fff;
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.sort-item {
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
}

.sort-item.active {
  color: var(--primary);
  font-weight: 500;
}

.sort-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.video-list-item {
  display: flex;
  gap: 20rpx;
  margin: 16rpx 24rpx 0;
  padding: 20rpx;
  align-items: flex-start;
}

.list-thumb {
  width: 200rpx;
  height: 120rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #1a1a2e;
}

.list-thumb-img {
  width: 100%;
  height: 100%;
}

.list-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a1a2e, #2d2d4e);
  color: rgba(255,255,255,0.3);
  font-size: 36rpx;
}

.list-info {
  flex: 1;
  min-width: 0;
}

.list-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.list-game {
  font-size: 24rpx;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.list-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.list-uploader {
  font-size: 22rpx;
  color: var(--text-hint);
}

.list-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.list-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.no-more {
  text-align: center;
  color: var(--text-hint);
  font-size: 24rpx;
  padding: 32rpx;
}

.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
