/* pages/upload/upload.wxss */

.upload-wrap {
  padding: 24rpx;
  background: var(--bg);
  min-height: 100vh;
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.field-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.field-label.required::before {
  content: '* ';
  color: var(--danger);
}

/* 视频选择 */
.video-picker {
  width: 100%;
  border-radius: 16rpx;
  background: var(--bg);
  border: 2rpx dashed var(--border);
  overflow: hidden;
  position: relative;
}

.video-picker.has-video {
  border: none;
}

.picker-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  gap: 12rpx;
}

.picker-icon {
  font-size: 64rpx;
}

.picker-tip {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.picker-sub {
  font-size: 24rpx;
  color: var(--text-hint);
}

.preview-video {
  width: 100%;
  height: 360rpx;
  display: block;
}

.re-select-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.55);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.video-meta-row {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 文本输入 */
.field-input {
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  width: 100%;
  box-sizing: border-box;
}

.field-ph {
  color: var(--text-hint);
}

.field-textarea {
  font-size: 28rpx;
  color: var(--text-primary);
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
  width: 100%;
  box-sizing: border-box;
  min-height: 120rpx;
  line-height: 1.6;
}

/* 分类选择器 */
.picker-show {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
}

/* AI 润色按钮 */
.field-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.field-label-row .field-label {
  margin-bottom: 0;
}

.ai-polish-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #6c63ff 0%, #a855f7 100%);
  border-radius: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(108, 99, 255, 0.3);
  transition: all 0.2s;
}

.ai-polish-btn.disabled {
  background: #ccc;
  box-shadow: none;
}

.ai-polish-btn.polishing {
  opacity: 0.7;
}

.polish-icon {
  font-size: 24rpx;
}

.polish-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.polish-spinner {
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 分类选择器 */
.picker-show {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  border: 1rpx solid var(--border);
}

.picker-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-arrow {
  font-size: 36rpx;
  color: var(--text-hint);
}

/* 上传按钮 */
.upload-btn-wrap {
  margin-top: 16rpx;
  padding-bottom: 40rpx;
}

.upload-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-btn.disabled {
  background: #a0a0c8;
}

.btn-loading {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
