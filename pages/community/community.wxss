/* pages/community/community.wxss */

.community-wrap {
  background: var(--bg);
  min-height: 100vh;
}

/* 头部 */
.community-header {
  background: #fff;
  padding: 28rpx 28rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid var(--border);
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.header-sub {
  font-size: 24rpx;
  color: var(--text-hint);
  display: block;
  margin-top: 4rpx;
}

.upload-entry-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 14rpx 28rpx;
  font-size: 28rpx;
}

/* 信息流 */
.feed-list {
  padding: 20rpx 24rpx;
}

.feed-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.feed-thumb-wrap {
  width: 100%;
  padding-top: 52%;
  position: relative;
  background: #1a1a2e;
  overflow: hidden;
}

.feed-thumb {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.feed-thumb-ph {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a1a2e, #2d2d4e);
}

.ph-icon {
  font-size: 64rpx;
  color: rgba(255,255,255,0.2);
}

.feed-duration {
  position: absolute;
  bottom: 12rpx;
  right: 16rpx;
  background: rgba(0,0,0,0.65);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.feed-game-badge {
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.feed-info {
  padding: 20rpx 24rpx 24rpx;
}

.feed-row1 {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.feed-avatar-wrap {
  flex-shrink: 0;
}

.feed-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.feed-avatar-ph {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

.feed-meta {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.feed-uploader {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.feed-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.feed-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.feed-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.feed-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  gap: 20rpx;
}

.icon {
  font-size: 80rpx;
}

.tip {
  font-size: 28rpx;
  color: var(--text-hint);
  text-align: center;
  line-height: 1.8;
}

.upload-first-btn {
  margin-top: 20rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 16rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
}

.no-more {
  text-align: center;
  color: var(--text-hint);
  font-size: 24rpx;
  padding: 32rpx;
}

.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}

.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
