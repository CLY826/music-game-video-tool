/* pages/search/search.wxss */

.search-wrap {
  min-height: 100vh;
  background: var(--bg);
}

.search-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: #fff;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.search-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 40rpx;
  padding: 14rpx 20rpx;
  gap: 12rpx;
}

.search-ico {
  font-size: 28rpx;
}

.search-ipt {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-ph {
  font-size: 28rpx;
  color: var(--text-hint);
}

.clear-btn {
  color: var(--text-hint);
  font-size: 28rpx;
  padding: 4rpx 8rpx;
}

.search-submit-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
  gap: 20rpx;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-hint);
}

.result-count {
  padding: 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.count-num {
  color: var(--primary);
  font-weight: 600;
}

.result-item {
  display: flex;
  margin: 0 24rpx 16rpx;
  padding: 20rpx;
  gap: 20rpx;
  align-items: flex-start;
}

.result-thumb {
  width: 160rpx;
  height: 96rpx;
  border-radius: 10rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #1a1a2e;
}

.result-thumb-img {
  width: 100%;
  height: 100%;
}

.result-thumb-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: rgba(255,255,255,0.3);
}

.result-info {
  flex: 1;
  min-width: 0;
}

.result-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.result-game {
  font-size: 24rpx;
  color: var(--primary);
  display: block;
  margin-bottom: 8rpx;
}

.result-meta {
  display: flex;
  justify-content: space-between;
}

.result-uploader, .result-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.guide {
  display: flex;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.guide-tip {
  font-size: 28rpx;
  color: var(--text-hint);
}

.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
