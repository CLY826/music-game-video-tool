/* pages/index/index.wxss - 首页样式 */

.index-wrap {
  background: var(--bg);
  min-height: 100vh;
}

/* header */
.header {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 40rpx 28rpx 32rpx;
}

.header-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.logo {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.title-text {
  font-size: 40rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* 搜索框 */
.search-bar {
  margin-top: 8rpx;
}

.search-inner {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.12);
  border-radius: 44rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  color: #ffffff;
  font-size: 28rpx;
  background: transparent;
}

.search-placeholder {
  color: rgba(255,255,255,0.4);
  font-size: 28rpx;
}

.search-btn {
  background: var(--primary);
  color: #fff;
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  margin-left: 12rpx;
}

/* 快捷入口 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  margin: 20rpx 24rpx 0;
  padding: 28rpx 12rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.upload-icon { background: #ede9ff; }
.search-action-icon { background: #e3f2fd; }
.all-icon { background: #f3e5f5; }

.action-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* section 区块 */
.section {
  margin: 20rpx 0;
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  position: relative;
  padding-left: 16rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 6rpx;
  height: 32rpx;
  width: 6rpx;
  background: var(--primary);
  border-radius: 3rpx;
}

/* 分类横向滚动 */
.games-scroll {
  white-space: nowrap;
  margin: 0 -24rpx;
  padding: 0 24rpx;
}

.games-list {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 24rpx;
}

.game-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  width: 120rpx;
}

.game-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-emoji {
  font-size: 40rpx;
}

.game-name {
  font-size: 22rpx;
  color: var(--text-primary);
  text-align: center;
  white-space: normal;
  word-break: break-all;
  max-width: 120rpx;
  line-height: 1.3;
}

.game-count {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* 视频网格 */
.video-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.video-card {
  padding: 0;
  overflow: hidden;
  border-radius: 20rpx;
}

.thumb-wrap {
  position: relative;
  width: 100%;
  padding-top: 56.25%;
  background: #1a1a2e;
  border-radius: 16rpx 16rpx 0 0;
  overflow: hidden;
}

.video-thumb {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.thumb-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a1a2e, #2d2d4e);
}

.thumb-icon {
  font-size: 48rpx;
  color: rgba(255,255,255,0.3);
}

.duration-badge {
  position: absolute;
  bottom: 8rpx;
  right: 10rpx;
  background: rgba(0,0,0,0.65);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
}

.video-info {
  padding: 16rpx;
}

.video-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.video-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.game-tag {
  font-size: 22rpx;
  font-weight: 500;
}

.upload-time {
  font-size: 20rpx;
  color: var(--text-hint);
}

.uploader {
  font-size: 22rpx;
  color: var(--text-hint);
}

/* loading */
.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
