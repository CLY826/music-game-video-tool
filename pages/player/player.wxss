/* pages/player/player.wxss */

.loading-full {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  gap: 20rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

.player-wrap {
  background: var(--bg);
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* 视频容器 */
.video-container {
  width: 100%;
  background: #000;
  position: relative;
  transition: all 0.25s ease;
}

/* CSS 模拟全屏 —— 铺满整个屏幕 */
.video-container.fake-fullscreen {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 999;
  background: #000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.video-container.fake-fullscreen .main-video {
  width: 100%;
  height: 100%;
}

/* 全屏时隐藏页面其余内容 */
.player-wrap.fake-fs .info-section,
.player-wrap.fake-fs .progress-section,
.player-wrap.fake-fs .rate-section,
.player-wrap.fake-fs .ab-section,
.player-wrap.fake-fs .comment-section {
  display: none;
}

/* 全屏时遮罩，遮挡视频下方的内容 */
.fake-fullscreen-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 998;
  background: #000;
}

.main-video {
  width: 100%;
  height: 420rpx;
  display: block;
}

.ab-indicator {
  position: absolute;
  top: 16rpx;
  right: 76rpx; /* 为全屏按钮留出空间 */
}

.ab-badge {
  background: rgba(108, 99, 255, 0.85);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 非全屏时右下角全屏按钮 */
.fullscreen-btn {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fullscreen-icon {
  font-size: 32rpx;
  color: #fff;
  line-height: 1;
}

/* 全屏悬浮控制层 */
.fullscreen-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none; /* 默认穿透，按钮单独开启 */
}

/* 左上角：退出全屏按钮 */
.fs-exit-btn {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 32rpx;
  padding: 10rpx 22rpx 10rpx 16rpx;
  pointer-events: auto;
}

.fs-icon {
  font-size: 26rpx;
  color: #fff;
  line-height: 1;
}

.fs-label {
  font-size: 24rpx;
  color: #fff;
}

/* 右上角：播放/暂停按钮 */
.fs-play-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(108, 99, 255, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.fs-play-icon {
  font-size: 32rpx;
  color: #fff;
  line-height: 1;
}

/* 全屏右下角 AB 循环角标 */
.fs-ab-badge {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(108, 99, 255, 0.85);
  border-radius: 20rpx;
  padding: 6rpx 16rpx;
  pointer-events: none;
}

.fs-ab-badge text {
  font-size: 24rpx;
  color: #fff;
}

/* 信息区 */
.info-section {
  background: #fff;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid var(--border);
}

.song-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8rpx;
}

.song-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.info-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

/* 收藏按钮 */
.fav-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: var(--bg);
  border: 2rpx solid var(--border);
  border-radius: 32rpx;
  padding: 10rpx 20rpx;
}

.fav-btn.fav-active {
  background: #fff0f5;
  border-color: #ff6b9d;
}

.fav-icon {
  font-size: 30rpx;
  color: var(--text-hint);
  line-height: 1;
}

.fav-btn.fav-active .fav-icon {
  color: #ff6b9d;
}

.fav-label {
  font-size: 24rpx;
  color: var(--text-hint);
}

.fav-btn.fav-active .fav-label {
  color: #ff6b9d;
}

.song-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.game-tag {
  font-size: 26rpx;
  font-weight: 500;
}

.uploader-tip {
  font-size: 24rpx;
  color: var(--text-hint);
}

.song-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 进度条区 */
.progress-section {
  background: #fff;
  padding: 20rpx 24rpx 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  position: relative;
}

/* 播放/暂停按钮 */
.play-pause-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.play-pause-icon {
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}

.time-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  min-width: 72rpx;
}

.progress-slider {
  flex: 1;
  margin: 0;
}

.ab-markers {
  position: absolute;
  top: 32rpx;
  left: 96rpx;
  right: 96rpx;
  height: 0;
  pointer-events: none;
}

.marker-a, .marker-b {
  position: absolute;
  top: -16rpx;
  transform: translateX(-50%);
}

.marker-label {
  font-size: 20rpx;
  font-weight: 600;
  color: var(--primary);
  background: var(--primary-light);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--primary);
}

/* 控制区通用 */
.ctrl-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

/* 变速区 */
.rate-section {
  background: #fff;
  padding: 24rpx 28rpx;
  margin-top: 16rpx;
}

.rate-list {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.rate-btn {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  border: 2rpx solid var(--border);
  background: var(--bg);
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: all 0.15s;
}

.rate-btn.active {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
  font-weight: 500;
}

/* AB 循环区 */
.ab-section {
  background: #fff;
  padding: 24rpx 28rpx;
  margin-top: 16rpx;
}

.ab-controls {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ab-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.ab-point-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  border: 2rpx solid var(--border);
}

.a-btn {
  border-color: #6c63ff;
  background: #f0eeff;
}

.b-btn {
  border-color: #ff6b9d;
  background: #fff0f5;
}

.ab-btn-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.ab-point-time {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-family: monospace;
}

.ab-clear-btn {
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid var(--border);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.loop-toggle-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  border-radius: 16rpx;
}

.loop-toggle-btn.off {
  background: var(--bg);
  border: 2rpx solid var(--border);
}

.loop-toggle-btn.on {
  background: var(--primary);
  border: 2rpx solid var(--primary);
}

.loop-icon {
  font-size: 32rpx;
}

.loop-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.loop-toggle-btn.on .loop-text {
  color: #fff;
}

.ab-tip {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #f8f7ff;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: var(--text-hint);
}

/* 评论区 */
.comment-section {
  background: #fff;
  padding: 24rpx 28rpx;
  margin-top: 16rpx;
}

.comment-input-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: var(--bg);
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  border: 1rpx solid var(--border);
}

.comment-ph {
  color: var(--text-hint);
  font-size: 28rpx;
}

.comment-send-btn {
  background: var(--primary);
  color: #fff;
  border-radius: 40rpx;
  padding: 16rpx 28rpx;
  font-size: 28rpx;
  flex-shrink: 0;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--bg);
}

.comment-avatar-wrap {
  flex-shrink: 0;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
}

.comment-avatar-ph {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.comment-author {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.comment-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.comment-content {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  word-break: break-all;
}

.empty-comment {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: var(--text-hint);
}

.load-more, .no-more {
  text-align: center;
  padding: 24rpx;
  font-size: 26rpx;
  color: var(--text-hint);
}

.load-more {
  color: var(--primary);
}

.loading-dot {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

